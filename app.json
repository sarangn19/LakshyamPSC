{
  "expo": {
    "name": "Lakshyam",
    "slug": "lakshyam",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lakshyam.app"
    },
    "android": {
      "package": "com.lakshyam.app"
    },
    "web": {
      "favicon": "./icon.png",
      "manifest": {
        "display": "standalone",
        "shortName": "Lakshyam",
        "themeColor": "#2563EB",
        "backgroundColor": "#F4F0EF",
        "icons": [
          { "src": "./icon.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
          { "src": "./icon.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
        ]
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
